<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Clean Border (Holo Style) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1000EAFF"/> <!-- Slight tint -->
            <stroke android:width="1dp" android:color="@color/neon_blue"/>
            <corners android:radius="4dp"/> <!-- Sharp technological corners -->
        </shape>
    </item>
    
    <!-- Top Highlight Line (Tech Detail) -->
    <item android:top="0dp" android:left="8dp" android:right="8dp" android:bottom="0dp" android:height="2dp"> 
         <shape android:shape="rectangle">
             <solid android:color="@color/neon_blue"/>
         </shape>
    </item>
</layer-list>
