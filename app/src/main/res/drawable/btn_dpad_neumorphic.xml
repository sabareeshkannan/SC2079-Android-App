<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed State: Inset/Active Glow -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#3300EAFF"/> <!-- Translucent Blue Fill -->
            <stroke android:width="1dp" android:color="@color/neon_blue"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>

    <!-- Normal State: Glassy/Tech Plate -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1AFFFFFF"/> <!-- Very subtle fill -->
            <stroke android:width="1dp" android:color="#33FFFFFF"/> <!-- Subtle border -->
            <corners android:radius="8dp"/>
        </shape>
    </item>
</selector>
