<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#10FF0000"/>
            <stroke android:width="1dp" android:color="@color/neon_red"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>
    <item android:top="0dp" android:left="8dp" android:right="8dp" android:bottom="0dp" android:height="2dp"> 
         <shape android:shape="rectangle">
             <solid android:color="@color/neon_red"/>
         </shape>
    </item>
</layer-list>
