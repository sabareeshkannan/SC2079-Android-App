<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Active State (Filled) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#4000EAFF"/> <!-- Filled when pressed -->
            <stroke android:width="1dp" android:color="@color/neon_blue"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>
    
    <item android:top="0dp" android:left="8dp" android:right="8dp" android:bottom="0dp" android:height="2dp"> 
         <shape android:shape="rectangle">
             <solid android:color="@color/white"/> <!-- Bright highlight -->
         </shape>
    </item>
</layer-list>
